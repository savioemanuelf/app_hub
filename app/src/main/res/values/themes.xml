<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base claro -->
    <style name="Base.Theme.AppHub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hub_primary</item>
        <item name="colorPrimaryDark">@color/hub_primary_dark</item>
        <item name="colorAccent">@color/hub_accent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/hub_background_light</item>
    </style>

    <style name="Theme.AppHub" parent="Base.Theme.AppHub" />

    <!-- Tema para a CalculadoraActivity -->
    <style name="Theme.AppHub.Calculadora" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/calc_btn_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/calc_btn_operator</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Tema para a PlacarActivity -->
    <style name="Theme.AppHub.Placar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/placar_botao_iniciar</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>