<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/jogoDaVelhaScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_large">

        <!-- Status do jogo (vez do jogador / resultado) -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_velha"
            android:textSize="@dimen/velha_status_size"
            android:textStyle="bold"
            android:textColor="@color/hub_primary"
            android:layout_marginBottom="@dimen/margin_small" />

        <!-- Placar X vs O -->
        <TextView
            android:id="@+id/txtPlacar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_subtitle"
            android:textColor="@color/hub_text_secondary_light"
            android:layout_marginBottom="@dimen/margin_large" />

        <!-- Tabuleiro 3x3 -->
        <GridLayout
            android:id="@+id/gridTabuleiro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:layout_marginBottom="@dimen/margin_large">

            <!-- Linha 0 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell00"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell01"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell02"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_margin="4dp" />

            <!-- Linha 1 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell10"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell11"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell12"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_margin="4dp" />

            <!-- Linha 2 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell20"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell21"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_margin="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cell22"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="@dimen/velha_cell_size"
                android:layout_height="@dimen/velha_cell_size"
                android:textSize="@dimen/velha_symbol_size"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_margin="4dp" />

        </GridLayout>

        <!-- Botão de reiniciar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReiniciar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/velha_reiniciar"
            android:textSize="@dimen/text_button" />

    </LinearLayout>
</ScrollView>
